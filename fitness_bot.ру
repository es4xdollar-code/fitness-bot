def send_reminders():
    while True:
        now = datetime.now()
        current_hour = now.hour
        current_minute = now.minute
        for user_id, user in list(users.items()):
            chat_id = user.get('chat_id')
            if not chat_id:
                continue
            if user.get('water_reminder'):
                wake = user.get('wake_hour', 7)
                if wake <= current_hour <= 22 and current_minute == 0:
                    if (current_hour - wake) % 2 == 0:
                        try:
                            bot.send_message(chat_id,
"💧 Время пить воду!\n\nВыпей стакан воды прямо сейчас 🥛\n✅ Ускоряет метаболизм\n✅ Улучшает самочувствие")
                        except:
                            pass
            if user.get('sleep_reminder'):
                sleep_hour = user.get('sleep_hour', 23)
                warn_hour = (sleep_hour - 1) % 24
                if current_hour == warn_hour and current_minute == 30:
                    try:
                        bot.send_message(chat_id,
f"🌙 Через 30 минут пора спать!\n\nГотовься ко сну:\n📵 Отложи телефон\n🪟 Проветри комнату\n😴 Ложись в {sleep_hour}:00")
                    except:
                        pass
                if current_hour == sleep_hour and current_minute == 0:
                    try:
                        bot.send_message(chat_id,
"🌙 Пора спать!\n\nХорошего сна! 😴\nМышцы растут во сне! 💪")
                    except:
                        pass
        time.sleep(60)

reminder_thread = threading.Thread(target=send_reminders, daemon=True)
reminder_thread.start()

print("✅ Бот запущен!")
