def get_user(user_id):
    if user_id not in users:
        users[user_id] = {
            'calories_today': 0,
            'weight': None,
            'height': None,
            'age': None,
            'gender': None,
            'goal': None,
            'norm': None,
            'food_log': [],
            'water_reminder': False,
            'sleep_reminder': False,
            'wake_hour': 7,
            'sleep_hour': 23,
            'chat_id': None
        }
    return users[user_id]

def calc_norm(weight, height, age, gender, goal):
    if gender == 'male':
        bmr = 10 * weight + 6.25 * height - 5 * age + 5
    else:
        bmr = 10 * weight + 6.25 * height - 5 * age - 161
    tdee = bmr * 1.55
    if goal == 'loss':
        return int(tdee - 500)
    elif goal == 'mass':
        return int(tdee + 400)
    else:
        return int(tdee)

def progress_bar(current, total):
    percent = min(int((current / total) * 10), 10)
    bar = '🟩' * percent + '⬜' * (10 - percent)
    return bar

