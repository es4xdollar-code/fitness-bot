@bot.message_handler(func=lambda m: '➕ Добавить приём пищи' in m.text)
def add_food(message):
    food_list = '\n'.join([f"• {k.capitalize()} — {v} ккал" for k, v in list(FOOD_DB.items())[:15]])
    bot.send_message(message.chat.id,
f"""➕ Добавить еду

Напиши продукт и граммы.
Например: курица 200

📋 Продукты (ккал/100г):
{food_list}""")
    bot.register_next_step_handler(message, process_food)

def process_food(message):
    if any(x in message.text for x in ['🥗', '💪', '📊', '🔙', '➕', '📈', '📋', '🍽', '🔄', '💧', '❓']):
        bot.process_new_messages([message])
        return
    user = get_user(message.chat.id)
    text = message.text.lower().strip()
    found = False
    for food, cal_per_100 in FOOD_DB.items():
        if food in text:
            try:
                digits = ''.join(filter(lambda x: x.isdigit() or x == '.', text.replace(food, '')))
                grams = float(digits)
                calories = int(cal_per_100 * grams / 100)
                user['calories_today'] += calories
                user['food_log'].append(f"{food.capitalize()} {grams}г — {calories} ккал")
                norm = user.get('norm') or 2000
                current = user['calories_today']
                bar = progress_bar(current, norm)
                remaining = norm - current
                bot.send_message(message.chat.id,
f"""✅ Записал!

🍽 {food.capitalize()} {grams}г
🔥 {calories} ккал

📊 Прогресс за день:
{bar}
{current} / {norm} ккал
{'✅ Норма выполнена!' if current >= norm else f'Осталось: {remaining} ккал'}""")
                found = True
                break
            except:
                bot.send_message(message.chat.id, "Напиши так: курица 200")
                found = True
                break
    if not found:
        bot.send_message(message.chat.id, "❌ Продукт не найден. Попробуй другой из списка.")

